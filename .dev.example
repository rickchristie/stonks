# Required local development config.
# Copy this file to .dev and change DB_NAME / ports for another repo or agent session.
# This allows multiple checkouts to run backend, web, database resets, and Playwright without collisions.

DEV_BACKEND_HOST=localhost
DEV_BACKEND_PORT=8800
DEV_WEB_HOST=localhost
DEV_WEB_PORT=8801

# Empty bind host preserves Go server ":PORT" behavior.
BACKEND_HOST=

DB_HOST=localhost
DB_PORT=5432
DB_USER=stonks
DB_PASSWORD=stonks_local_dev_pwd
DB_NAME=stonks

JWT_SECRET=stonks-jwt-secret-change-in-production

CORS_ALLOWED_ORIGINS=http://localhost:8801
VITE_API_BASE=http://localhost:8800
PLAYWRIGHT_BASE_URL=http://localhost:8801
PLAYWRIGHT_API_BASE=http://localhost:8800
