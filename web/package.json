{
	"name": "app-template-web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"engines": {
		"node": ">=22.12.0",
		"npm": ">=11.16.0"
	},
	"overrides": {
		"cookie": "^0.7.0"
	},
	"scripts": {
		"dev": "../scripts/dev-web-command.sh",
		"dev:clean": "../scripts/dev-web-command.sh --clean",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.48.5",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/node": "^25.9.1",
		"autoprefixer": "^10.4.22",
		"jsdom": "^27.4.0",
		"postcss": "^8.5.6",
		"svelte": "^5.43.8",
		"svelte-check": "^4.3.4",
		"tailwindcss": "^3.4.18",
		"typescript": "^5.9.3",
		"vite": "^7.2.2",
		"vitest": "^4.0.16"
	}
}
